#!/usr/bin/make -f

PKG_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/~.*//')
PKG_SOURCE  := $(shell jq -r '.name' composer.json)
PKG_TYPE    := $(shell jq -r '.type' composer.json)

%:
	dh $@

override_dh_clean:
	rm -rf vendor/*
	dh_clean

override_dh_auto_test:
	appstreamcli validate --pedantic --no-net \
	    debian/pohoda-realpad.metainfo.xml

override_dh_install:
	dh_install
	install -m 644 debian/autoload.php \
	    debian/pohoda-realpad/usr/lib/pohoda-realpad/autoload.php
	sed -i "s|require_once '../vendor/autoload.php'|require_once '/usr/lib/pohoda-realpad/autoload.php'|" \
	    debian/pohoda-realpad/usr/lib/pohoda-realpad/pohoda-bank-to-realpad.php
	sed -i "s|\.\./\.env||g" \
	    debian/pohoda-realpad/usr/lib/pohoda-realpad/pohoda-bank-to-realpad.php
	sed -i "1a defined('APP_NAME') || define('APP_NAME', '$(PKG_SOURCE)');" \
	    debian/pohoda-realpad/usr/lib/pohoda-realpad/autoload.php
	sed -i "s|'unknown'|'$(PKG_SOURCE)'|" \
	    debian/pohoda-realpad/usr/lib/pohoda-realpad/autoload.php
	sed -i "s|'0.0.0'|'$(PKG_VERSION)'|" \
	    debian/pohoda-realpad/usr/lib/pohoda-realpad/autoload.php
	sed -i "s|'library'|'$(PKG_TYPE)'|g" \
	    debian/pohoda-realpad/usr/lib/pohoda-realpad/autoload.php
	sed -i "2a defined('APP_VERSION') || define('APP_VERSION', '$(PKG_VERSION)');" \
	    debian/pohoda-realpad/usr/lib/pohoda-realpad/autoload.php
	jq '.version = "$(PKG_VERSION)"' multiflexi/pohoda-bank-to-realpad.app.json > \
	    debian/multiflexi-pohoda-realpad/usr/lib/pohoda-realpad/multiflexi/pohoda-bank-to-realpad.app.json
